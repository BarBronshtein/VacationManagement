# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@postgres:5432/vacation_db
DATABASE_PORT=5432
DB_PORT=5432
DATABASE_USER=postgres
DB_USERNAME=postgres
DATABASE_PASSWORD=password
DB_PASSWORD=password
DATABASE_HOST=postgres
DB_HOST=postgres
DB_DATABASE=vacation_db
DB_SYNCHRONIZE=true

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=my-secret-JWt-Secret!@45-343

# ─── Mail (MailDev — catches mail locally in Docker) ───────
# Change MAIL_HOST=smtp.gmail.com + MAIL_PORT=587 to use real Gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=ENTER YOUR GMAIL
MAIL_PASS =ENTER YOUR IMAP PASSWORD
MAIL_FROM=ENTER YOUR GMAIL
APP_NAME=ENTER IMAP APP NAME